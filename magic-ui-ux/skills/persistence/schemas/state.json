{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project State",
  "type": "object",
  "properties": {
    "projectName": { "type": "string" },
    "niche": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "deviceType": {
      "type": "string",
      "enum": ["MOBILE", "DESKTOP", "TABLET", "AGNOSTIC"],
      "description": "Target device type for Stitch generation calls"
    },
    "stitch": {
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectUrl": { "type": "string" }
      }
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "page": { "type": "string" },
          "variant": { "type": "integer", "default": 0 },
          "createdAt": { "type": "string", "format": "date-time" },
          "stitchScreenId": { "type": "string" },
          "uxBriefPath": { "type": "string" },
          "deviceType": { "type": "string", "description": "Device type used for this screen generation" },
          "creativeRange": { "type": "string", "description": "Creative range used if this screen is a variant" },
          "modelId": { "type": "string", "description": "Stitch model ID used for generation" },
          "screenshotUrl": { "type": "string", "description": "Screenshot URL from Stitch get_screen response" },
          "screenshotPath": { "type": "string", "description": "Local path to saved screenshot image" },
          "syncStatus": { "type": "string", "enum": ["synced", "stale", "imported"], "description": "Sync status from /sync command" }
        },
        "required": ["id", "page"]
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "ux-briefed", "designed", "iterated"]
          },
          "uxBriefPath": { "type": "string" },
          "screenIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "status"]
      }
    },
    "brandingComplete": { "type": "boolean", "default": false },
    "animationSpecs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "specPath": { "type": "string" }
        }
      }
    },
    "scrollVideoSpecs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "specPath": { "type": "string" }
        }
      }
    },
    "exports": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "exportedAt": { "type": "string", "format": "date-time" },
          "exportPath": { "type": "string" }
        }
      }
    },
    "imageSpecs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "specPath": { "type": "string" },
          "guidanceText": { "type": "string", "description": "Pre-translated natural language for Stitch prompts" }
        }
      }
    }
  },
  "required": ["projectName", "niche", "createdAt"]
}
