{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Tokens",
  "type": "object",
  "properties": {
    "colors": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "cta": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "background": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "text": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "success": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "warning": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "error": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      },
      "required": ["primary", "secondary", "cta", "background", "text"]
    },
    "typography": {
      "type": "object",
      "properties": {
        "heading": {
          "type": "object",
          "properties": {
            "family": { "type": "string" },
            "weight": { "type": "string" },
            "googleFontsUrl": { "type": "string" }
          },
          "required": ["family"]
        },
        "body": {
          "type": "object",
          "properties": {
            "family": { "type": "string" },
            "weight": { "type": "string" },
            "googleFontsUrl": { "type": "string" }
          },
          "required": ["family"]
        },
        "accent": {
          "type": "object",
          "properties": {
            "family": { "type": "string" }
          }
        }
      },
      "required": ["heading", "body"]
    },
    "spacing": {
      "type": "object",
      "properties": {
        "unit": { "type": "string", "default": "rem" },
        "scale": { "type": "array", "items": { "type": "number" } }
      }
    },
    "uiStyle": {
      "type": "string",
      "description": "Recommended UI style (e.g., Minimalism, Glassmorphism, Neubrutalism)"
    },
    "industry": { "type": "string" },
    "componentPatterns": {
      "type": "object",
      "properties": {
        "header": { "type": "string" },
        "hero": { "type": "string" },
        "cta": { "type": "string" },
        "footer": { "type": "string" }
      }
    }
  },
  "required": ["colors", "typography"]
}
